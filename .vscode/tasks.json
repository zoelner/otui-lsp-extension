{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$esbuild"
    },
    {
      "label": "watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "group": "build",
      "problemMatcher": "$esbuild-watch"
    },
    {
      "label": "check",
      "type": "npm",
      "script": "check",
      "group": "test",
      "problemMatcher": "$tsc"
    }
  ]
}
