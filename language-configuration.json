{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "autoCloseBefore": ";:.,=}])> \n\t",
  "folding": {
    "offSide": true
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "indentationRules": {
    "comment": "A line that ends in `:` with no value opens a block; so does a bare tag or a `Name < Base` header. Nesting is two spaces per level.",
    "increaseIndentPattern": "^\\s*(?:[@&!]?[A-Za-z_][A-Za-z0-9_\\-]*|\\$\\s*!?[A-Za-z_][A-Za-z0-9_\\-]*(?:\\s+!?[A-Za-z_][A-Za-z0-9_\\-]*)*)\\s*:\\s*(?:\\|[-+]?)?\\s*$",
    "decreaseIndentPattern": "^\\s+$"
  },
  "onEnterRules": [
    {
      "comment": "`Name < Base` and a bare container tag both open a child block.",
      "beforeText": "^\\s*[A-Za-z_][A-Za-z0-9_\\-]*\\s*(?:<\\s*\\S.*)?$",
      "action": { "indent": "indent" }
    }
  ]
}
