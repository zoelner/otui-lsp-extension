{
  "name": "otui-vscode-extension",
  "displayName": "OTUI Language Support",
  "description": "Language support for OTUI/OTML (OTClient UI markup) — a thin VS Code client for the otui-lsp language server.",
  "version": "0.0.1",
  "publisher": "zoelner",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zoelner/otui-vscode-extension"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "workspaceContains:**/*.otui"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "otui",
        "aliases": [
          "OTUI",
          "OTML"
        ],
        "extensions": [
          ".otui",
          ".otmod",
          ".otfont"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "OTUI",
      "properties": {
        "otui.server.path": {
          "type": "string",
          "default": "otui-lsp",
          "markdownDescription": "Path to the `otui-lsp` server binary. Defaults to `otui-lsp` on your `PATH`. For a local build, set the absolute path to `target/release/otui-lsp`."
        },
        "otui.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the LSP communication between VS Code and the otui-lsp server (for debugging)."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0"
  }
}
